BOT_TOKEN=your_discord_bot_token

# Comma-separated Discord user IDs.
OWNER_IDS=

# Optional public support server URL.
SUPPORT_URL=

# Lavalink connection.
LAVALINK_NAME=AKARI
LAVALINK_URL=localhost:2333
LAVALINK_AUTH=your_lavalink_password
LAVALINK_SECURE=false

# Alternative Lavalink format. Use this instead of LAVALINK_URL if preferred.
# LAVALINK_HOST=localhost
# LAVALINK_PORT=2333
# LAVALINK_PASSWORD=your_lavalink_password

# Optional Spotify support.
SPOTIFY_ID=
SPOTIFY_SECRET=

# Optional Last.fm support.
LASTFM_KEY=
LASTFM_SECRET=
